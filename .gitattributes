# Auto-detect text files and normalise line endings to LF in the repo
* text=auto

# Force LF for source files
*.dart text eol=lf
*.php  text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.sh   text eol=lf

# Keep CRLF for Windows-specific files
*.bat  text eol=crlf
*.ps1  text eol=crlf
gradlew.bat text eol=crlf

# Treat binary files as binary (no conversion)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.apk  binary
*.pdf  binary
*.docx binary
*.zip  binary
*.jar  binary
*.aar  binary
*.so   binary
*.ttf  binary
*.otf  binary
*.woff binary
*.woff2 binary
